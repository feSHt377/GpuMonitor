<Window x:Class="GpuMonitor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GpuMonitor"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="GPU Monitor"
        Icon="icon.png"
        Topmost="True"
        ResizeMode="CanResizeWithGrip"
        Width="360" MinWidth="300"
        Height="520" MinHeight="200"
        Background="#1A1B1E"
        Loaded="Window_Loaded"
        Closing="Window_Closing">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome GlassFrameThickness="0" CornerRadius="0"
                            CaptionHeight="36" ResizeBorderThickness="4"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <SolidColorBrush x:Key="BgPrimary" Color="#1A1B1E"/>
        <SolidColorBrush x:Key="BgSecondary" Color="#25262B"/>
        <SolidColorBrush x:Key="BgCard" Color="#2C2E33"/>
        <SolidColorBrush x:Key="BorderColor" Color="#373A40"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#C1C2C5"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#909296"/>
        <SolidColorBrush x:Key="AccentGreen" Color="#51CF66"/>
        <SolidColorBrush x:Key="AccentYellow" Color="#FCC419"/>
        <SolidColorBrush x:Key="AccentOrange" Color="#FF922B"/>
        <SolidColorBrush x:Key="AccentRed" Color="#FF6B6B"/>
        <SolidColorBrush x:Key="AccentBlue" Color="#4DABF7"/>

        <local:GpuColorConverter x:Key="ColorConverter"/>

        <Style x:Key="CloseButton" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentRed}"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource BgCard}"/>
                    <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ComboBox 暗色主题 -->
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource BgCard}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Border Grid.Row="0" Background="{StaticResource BgSecondary}"
                Height="36" shell:WindowChrome.IsHitTestVisibleInChrome="True"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <TextBlock Text="🎮 GPU Monitor"
                               Foreground="{StaticResource TextPrimary}"
                               FontSize="13" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="12,0,0,0"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,4,0">
                        <Button x:Name="BtnMonitor" Style="{StaticResource IconButton}"
                                Content="📺" ToolTip="监控模式"
                                Click="BtnMonitor_Click"/>
                        <Button x:Name="BtnSettings" Style="{StaticResource IconButton}"
                                Content="⚙" ToolTip="设置"
                                Click="BtnSettings_Click"/>
                        <Button x:Name="BtnPin" Style="{StaticResource IconButton}"
                                Content="📌" ToolTip="置顶"
                                Click="BtnPin_Click"/>
                        <Button Style="{StaticResource CloseButton}"
                                Content="✕" ToolTip="关闭 (最小化到托盘)"
                                Click="BtnClose_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 设置面板 -->
            <Border x:Name="SettingsPanel" Grid.Row="1"
                    Background="{StaticResource BgSecondary}"
                    Visibility="Collapsed"
                    Padding="12,8">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="32"/>
                            <RowDefinition Height="32"/>
                            <RowDefinition Height="32"/>
                            <RowDefinition Height="32"/>
                            <RowDefinition Height="32"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="主机:" Foreground="{StaticResource TextSecondary}"
                                   VerticalAlignment="Center" FontSize="12"/>
                        <TextBox x:Name="TxtHost" Grid.Row="0" Grid.Column="1"
                                 Margin="0,0,0,4" Background="{StaticResource BgCard}"
                                 BorderBrush="{StaticResource BorderColor}"
                                 Foreground="{StaticResource TextPrimary}"
                                 CaretBrush="{StaticResource TextPrimary}"
                                 FontSize="12" Padding="6,4" VerticalContentAlignment="Center"/>

                        <TextBlock Text="用户名:" Grid.Row="1" Grid.Column="0"
                                   Foreground="{StaticResource TextSecondary}"
                                   VerticalAlignment="Center" FontSize="12"/>
                        <TextBox x:Name="TxtUser" Grid.Row="1" Grid.Column="1"
                                 Margin="0,0,0,4" Background="{StaticResource BgCard}"
                                 BorderBrush="{StaticResource BorderColor}"
                                 Foreground="{StaticResource TextPrimary}"
                                 CaretBrush="{StaticResource TextPrimary}"
                                 FontSize="12" Padding="6,4" VerticalContentAlignment="Center"/>

                        <TextBlock Text="密码:" Grid.Row="2" Grid.Column="0"
                                   Foreground="{StaticResource TextSecondary}"
                                   VerticalAlignment="Center" FontSize="12"/>
                        <PasswordBox x:Name="TxtPassword" Grid.Row="2" Grid.Column="1"
                                     Margin="0,0,0,4" Background="{StaticResource BgCard}"
                                     BorderBrush="{StaticResource BorderColor}"
                                     Foreground="{StaticResource TextPrimary}"
                                     CaretBrush="{StaticResource TextPrimary}"
                                     FontSize="12" Padding="6,4"
                                     VerticalContentAlignment="Center"/>

                        <TextBlock Text="端口:" Grid.Row="3" Grid.Column="0"
                                   Foreground="{StaticResource TextSecondary}"
                                   VerticalAlignment="Center" FontSize="12"/>
                        <TextBox x:Name="TxtPort" Grid.Row="3" Grid.Column="1"
                                 Text="22" Margin="0,0,0,4" Background="{StaticResource BgCard}"
                                 BorderBrush="{StaticResource BorderColor}"
                                 Foreground="{StaticResource TextPrimary}"
                                 CaretBrush="{StaticResource TextPrimary}"
                                 FontSize="12" Padding="6,4" VerticalContentAlignment="Center"/>

                        <TextBlock Text="刷新(s):" Grid.Row="4" Grid.Column="0"
                                   Foreground="{StaticResource TextSecondary}"
                                   VerticalAlignment="Center" FontSize="12"/>
                        <TextBox x:Name="TxtInterval" Grid.Row="4" Grid.Column="1"
                                 Text="3" Background="{StaticResource BgCard}"
                                 BorderBrush="{StaticResource BorderColor}"
                                 Foreground="{StaticResource TextPrimary}"
                                 CaretBrush="{StaticResource TextPrimary}"
                                 FontSize="12" Padding="6,4" VerticalContentAlignment="Center"/>
                    </Grid>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                        <Button x:Name="BtnTestConn" Content="🔗 测试连接" Click="BtnTestConn_Click"
                                Width="90" Height="28" Margin="0,0,8,0" FontSize="11" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{StaticResource BgCard}"
                                            BorderBrush="{StaticResource BorderColor}"
                                            BorderThickness="1" CornerRadius="4" Padding="8,4">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button x:Name="BtnSave" Content="✅ 保存" Click="BtnSave_Click"
                                Width="70" Height="28" FontSize="11" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{StaticResource AccentGreen}"
                                            BorderThickness="0" CornerRadius="4" Padding="8,4">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>

                    <!-- 覆盖层设置分隔 -->
                    <Separator Margin="0,10,0,6" Background="{StaticResource BorderColor}" Height="1"/>
                    <TextBlock Text="📺 监控覆盖层设置"
                               Foreground="{StaticResource TextSecondary}" FontSize="11"
                               Margin="0,0,0,6"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="32"/>
                            <RowDefinition Height="32"/>
                            <RowDefinition Height="32"/>
                            <RowDefinition Height="32"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="停靠:" Grid.Row="0" Grid.Column="0"
                                   Foreground="{StaticResource TextSecondary}"
                                   VerticalAlignment="Center" FontSize="12"/>
                        <ComboBox x:Name="CmbOverlayEdge" Grid.Row="0" Grid.Column="1"
                                  Margin="0,0,0,4" Height="26"
                                  Background="{StaticResource BgCard}"
                                  BorderBrush="{StaticResource BorderColor}"
                                  Foreground="{StaticResource TextPrimary}"
                                  FontSize="12" VerticalContentAlignment="Center">
                            <ComboBoxItem Content="右侧" Tag="Right"/>
                            <ComboBoxItem Content="左侧" Tag="Left"/>
                            <ComboBoxItem Content="顶部" Tag="Top"/>
                            <ComboBoxItem Content="底部" Tag="Bottom"/>
                        </ComboBox>

                        <TextBlock Text="排版:" Grid.Row="1" Grid.Column="0"
                                   Foreground="{StaticResource TextSecondary}"
                                   VerticalAlignment="Center" FontSize="12"/>
                        <CheckBox x:Name="ChkCompact" Grid.Row="1" Grid.Column="1"
                                  Content="紧凑单行（减少屏幕占用）"
                                  Foreground="{StaticResource TextPrimary}"
                                  FontSize="12" VerticalContentAlignment="Center"
                                  VerticalAlignment="Center"/>

                        <TextBlock Text="透明度:" Grid.Row="2" Grid.Column="0"
                                   Foreground="{StaticResource TextSecondary}"
                                   VerticalAlignment="Center" FontSize="12"/>
                        <ComboBox x:Name="CmbOpacity" Grid.Row="2" Grid.Column="1"
                                  Margin="0,0,0,4" Height="26"
                                  Background="{StaticResource BgCard}"
                                  BorderBrush="{StaticResource BorderColor}"
                                  Foreground="{StaticResource TextPrimary}"
                                  FontSize="12" VerticalContentAlignment="Center">
                            <ComboBoxItem Content="90%（清晰）" Tag="0.9"/>
                            <ComboBoxItem Content="70%（推荐）" Tag="0.7"/>
                            <ComboBoxItem Content="50%（半透）" Tag="0.5"/>
                            <ComboBoxItem Content="30%（极透）" Tag="0.3"/>
                        </ComboBox>

                        <TextBlock Text="对齐:" Grid.Row="3" Grid.Column="0"
                                   Foreground="{StaticResource TextSecondary}"
                                   VerticalAlignment="Center" FontSize="12"/>
                        <ComboBox x:Name="CmbAlignment" Grid.Row="3" Grid.Column="1"
                                  Margin="0,0,0,4" Height="26"
                                  Background="{StaticResource BgCard}"
                                  BorderBrush="{StaticResource BorderColor}"
                                  Foreground="{StaticResource TextPrimary}"
                                  FontSize="12" VerticalContentAlignment="Center">
                            <ComboBoxItem Content="居中" Tag="Center"/>
                            <ComboBoxItem Content="左对齐" Tag="Left"/>
                            <ComboBoxItem Content="右对齐" Tag="Right"/>
                        </ComboBox>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- GPU 信息区域 -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="8,8,8,0">
                    <Border x:Name="NoDataBorder" Background="{StaticResource BgCard}"
                            CornerRadius="6" Padding="20" Margin="0,12"
                            Visibility="Collapsed">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="📡" FontSize="32" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TxtNoData" Text="请配置 SSH 连接后开始监控"
                                       Foreground="{StaticResource TextSecondary}"
                                       FontSize="13" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>
                    <TextBlock x:Name="TxtDriverInfo" Foreground="{StaticResource TextSecondary}"
                               FontSize="11" Margin="4,0,4,8" TextWrapping="Wrap"
                               Visibility="Collapsed"/>
                    <ItemsControl x:Name="GpuListControl"
                                  ItemsSource="{Binding GpuList}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource BgCard}"
                                        CornerRadius="6"
                                        BorderBrush="{StaticResource BorderColor}"
                                        BorderThickness="1"
                                        Padding="12" Margin="0,0,0,6">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name, StringFormat='⚡ GPU {0}'}"
                                                   Foreground="{StaticResource TextPrimary}"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"
                                                   Margin="0,0,0,8"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <!-- 温度 -->
                                            <Border Grid.Column="0"
                                                    Background="{StaticResource BgSecondary}"
                                                    CornerRadius="4" Padding="8,6" Margin="0,0,4,4">
                                                <StackPanel>
                                                    <TextBlock Text="🌡 温度" FontSize="10"
                                                               Foreground="{StaticResource TextSecondary}"/>
                                                    <TextBlock Text="{Binding Temperature, StringFormat='{}{0}°C'}"
                                                               FontSize="18" FontWeight="Bold"
                                                               Foreground="{Binding Temperature,
                                                                 Converter={StaticResource ColorConverter},
                                                                 ConverterParameter=temp}"/>
                                                </StackPanel>
                                            </Border>
                                            <!-- 利用率 -->
                                            <Border Grid.Column="1"
                                                    Background="{StaticResource BgSecondary}"
                                                    CornerRadius="4" Padding="8,6" Margin="0,0,0,4">
                                                <StackPanel>
                                                    <TextBlock Text="📊 利用率" FontSize="10"
                                                               Foreground="{StaticResource TextSecondary}"/>
                                                    <TextBlock Text="{Binding GpuUtilization, StringFormat='{}{0}%'}"
                                                               FontSize="18" FontWeight="Bold"
                                                               Foreground="{Binding GpuUtilization,
                                                                 Converter={StaticResource ColorConverter},
                                                                 ConverterParameter=util}"/>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                        <!-- 功耗 + 风扇 -->
                                        <Grid Margin="0,4,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0"
                                                    Background="{StaticResource BgSecondary}"
                                                    CornerRadius="4" Padding="8,6" Margin="0,0,4,0">
                                                <StackPanel>
                                                    <TextBlock Text="⚡ 功耗" FontSize="10"
                                                               Foreground="{StaticResource TextSecondary}"/>
                                                    <TextBlock Text="{Binding PowerUsage}"
                                                               FontSize="18" FontWeight="Bold"
                                                               Foreground="{StaticResource AccentBlue}"/>
                                                </StackPanel>
                                            </Border>
                                            <Border Grid.Column="1"
                                                    Background="{StaticResource BgSecondary}"
                                                    CornerRadius="4" Padding="8,6" Margin="0,0,0,0">
                                                <StackPanel>
                                                    <TextBlock Text="🌀 风扇" FontSize="10"
                                                               Foreground="{StaticResource TextSecondary}"/>
                                                    <TextBlock Text="{Binding FanSpeed, StringFormat='{}{0}%'}"
                                                               FontSize="18" FontWeight="Bold"
                                                               Foreground="{Binding FanSpeed,
                                                                 Converter={StaticResource ColorConverter},
                                                                 ConverterParameter=fan}"/>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                        <!-- 显存 -->
                                        <TextBlock Text="{Binding MemoryUsage, StringFormat='💾 显存: {0}'}"
                                                   Foreground="{StaticResource TextSecondary}"
                                                   FontSize="10" Margin="0,6,0,0"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>

            <!-- 状态栏 -->
            <Border Grid.Row="3" Background="{StaticResource BgSecondary}"
                    Height="28" Padding="10,0">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse x:Name="StatusDot" Width="8" Height="8"
                                 Fill="{StaticResource TextSecondary}" Margin="0,0,6,0"/>
                        <TextBlock x:Name="TxtStatus" Text="未连接"
                                   Foreground="{StaticResource TextSecondary}" FontSize="11"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock x:Name="TxtLastUpdate" Text=""
                                   Foreground="{StaticResource TextSecondary}" FontSize="11"/>
                        <Button x:Name="BtnRefresh" Style="{StaticResource IconButton}"
                                Content="🔄" ToolTip="手动刷新" Click="BtnRefresh_Click"
                                Width="24" Height="24" Margin="6,0,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
</Window>
