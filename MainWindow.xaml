<Window x:Class="GpuMonitor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GpuMonitor"
        mc:Ignorable="d"
        Title="GPU Monitor"
        Topmost="True"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip"
        Width="360" MinWidth="300"
        Height="520" MinHeight="200"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        Loaded="Window_Loaded"
        Closing="Window_Closing">

    <Window.Resources>
        <SolidColorBrush x:Key="BgPrimary" Color="#1A1B1E"/>
        <SolidColorBrush x:Key="BgSecondary" Color="#25262B"/>
        <SolidColorBrush x:Key="BgCard" Color="#2C2E33"/>
        <SolidColorBrush x:Key="BorderColor" Color="#373A40"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#C1C2C5"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#909296"/>
        <SolidColorBrush x:Key="AccentGreen" Color="#51CF66"/>
        <SolidColorBrush x:Key="AccentYellow" Color="#FCC419"/>
        <SolidColorBrush x:Key="AccentOrange" Color="#FF922B"/>
        <SolidColorBrush x:Key="AccentRed" Color="#FF6B6B"/>
        <SolidColorBrush x:Key="AccentBlue" Color="#4DABF7"/>

        <Style x:Key="CloseButton" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentRed}"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource BgCard}"/>
                    <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource BgPrimary}"
            BorderBrush="{StaticResource BorderColor}"
            BorderThickness="1"
            CornerRadius="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 标题栏 -->
            <Border Grid.Row="0" Background="{StaticResource BgSecondary}"
                    CornerRadius="9,9,0,0" Height="36"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <TextBlock Text="🎮 GPU Monitor"
                               Foreground="{StaticResource TextPrimary}"
                               FontSize="13" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="12,0,0,0"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,4,0">
                        <Button x:Name="BtnSettings" Style="{StaticResource IconButton}"
                                Content="⚙" ToolTip="设置"
                                Click="BtnSettings_Click"/>
                        <Button x:Name="BtnPin" Style="{StaticResource IconButton}"
                                Content="📌" ToolTip="置顶"
                                Click="BtnPin_Click"/>
                        <Button Style="{StaticResource CloseButton}"
                                Content="✕" ToolTip="关闭 (最小化到托盘)"
                                Click="BtnClose_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 设置面板 -->
            <Border x:Name="SettingsPanel" Grid.Row="1"
                    Background="{StaticResource BgSecondary}"
                    Visibility="Collapsed"
                    Padding="12,8">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="32"/>
                            <RowDefinition Height="32"/>
                            <RowDefinition Height="32"/>
                            <RowDefinition Height="32"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="主机:" Foreground="{StaticResource TextSecondary}"
                                   VerticalAlignment="Center" FontSize="12"/>
                        <TextBox x:Name="TxtHost" Grid.Row="0" Grid.Column="1"
                                 Margin="0,0,0,4" Background="{StaticResource BgCard}"
                                 BorderBrush="{StaticResource BorderColor}"
                                 Foreground="{StaticResource TextPrimary}"
                                 CaretBrush="{StaticResource TextPrimary}"
                                 FontSize="12" Padding="6,4" VerticalContentAlignment="Center"/>

                        <TextBlock Text="用户名:" Grid.Row="1" Grid.Column="0"
                                   Foreground="{StaticResource TextSecondary}"
                                   VerticalAlignment="Center" FontSize="12"/>
                        <TextBox x:Name="TxtUser" Grid.Row="1" Grid.Column="1"
                                 Margin="0,0,0,4" Background="{StaticResource BgCard}"
                                 BorderBrush="{StaticResource BorderColor}"
                                 Foreground="{StaticResource TextPrimary}"
                                 CaretBrush="{StaticResource TextPrimary}"
                                 FontSize="12" Padding="6,4" VerticalContentAlignment="Center"/>

                        <TextBlock Text="端口:" Grid.Row="2" Grid.Column="0"
                                   Foreground="{StaticResource TextSecondary}"
                                   VerticalAlignment="Center" FontSize="12"/>
                        <TextBox x:Name="TxtPort" Grid.Row="2" Grid.Column="1"
                                 Text="22" Margin="0,0,0,4" Background="{StaticResource BgCard}"
                                 BorderBrush="{StaticResource BorderColor}"
                                 Foreground="{StaticResource TextPrimary}"
                                 CaretBrush="{StaticResource TextPrimary}"
                                 FontSize="12" Padding="6,4" VerticalContentAlignment="Center"/>

                        <TextBlock Text="刷新(s):" Grid.Row="3" Grid.Column="0"
                                   Foreground="{StaticResource TextSecondary}"
                                   VerticalAlignment="Center" FontSize="12"/>
                        <TextBox x:Name="TxtInterval" Grid.Row="3" Grid.Column="1"
                                 Text="3" Background="{StaticResource BgCard}"
                                 BorderBrush="{StaticResource BorderColor}"
                                 Foreground="{StaticResource TextPrimary}"
                                 CaretBrush="{StaticResource TextPrimary}"
                                 FontSize="12" Padding="6,4" VerticalContentAlignment="Center"/>
                    </Grid>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                        <Button x:Name="BtnTestConn" Content="🔗 测试连接" Click="BtnTestConn_Click"
                                Width="90" Height="28" Margin="0,0,8,0" FontSize="11" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{StaticResource BgCard}"
                                            BorderBrush="{StaticResource BorderColor}"
                                            BorderThickness="1" CornerRadius="4" Padding="8,4">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button x:Name="BtnSave" Content="✅ 保存" Click="BtnSave_Click"
                                Width="70" Height="28" FontSize="11" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{StaticResource AccentGreen}"
                                            BorderThickness="0" CornerRadius="4" Padding="8,4">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- GPU 信息区域 -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="GpuStackPanel" Margin="8,8,8,0">
                    <Border x:Name="NoDataBorder" Background="{StaticResource BgCard}"
                            CornerRadius="6" Padding="20" Margin="0,12">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="📡" FontSize="32" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TxtNoData" Text="请配置 SSH 连接后开始监控"
                                       Foreground="{StaticResource TextSecondary}"
                                       FontSize="13" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>
                    <TextBlock x:Name="TxtDriverInfo" Foreground="{StaticResource TextSecondary}"
                               FontSize="11" Margin="4,0,4,8" TextWrapping="Wrap"
                               Visibility="Collapsed"/>
                </StackPanel>
            </ScrollViewer>

            <!-- 状态栏 -->
            <Border Grid.Row="3" Background="{StaticResource BgSecondary}"
                    CornerRadius="0,0,9,9" Height="28" Padding="10,0">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse x:Name="StatusDot" Width="8" Height="8"
                                 Fill="{StaticResource TextSecondary}" Margin="0,0,6,0"/>
                        <TextBlock x:Name="TxtStatus" Text="未连接"
                                   Foreground="{StaticResource TextSecondary}" FontSize="11"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock x:Name="TxtLastUpdate" Text=""
                                   Foreground="{StaticResource TextSecondary}" FontSize="11"/>
                        <Button x:Name="BtnRefresh" Style="{StaticResource IconButton}"
                                Content="🔄" ToolTip="手动刷新" Click="BtnRefresh_Click"
                                Width="24" Height="24" Margin="6,0,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
